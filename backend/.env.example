# SQLite 파일 경로 (절대/상대 모두 가능)
DATABASE_URL=sqlite:///./latale.db

# JWT 서명 키 — 운영 시 반드시 임의 32+ 글자로 교체
# 예: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string-please

# JWT 만료 (초). 7일 = 604800
JWT_EXPIRE_SECONDS=604800

# CORS 허용 origin (콤마 구분)
CORS_ORIGINS=http://localhost:5173,https://latale-calculator.vercel.app

# bcrypt 비용 (높을수록 안전·느림, 12 가 보편)
BCRYPT_ROUNDS=12
